# Please keep this file sorted (LC_COLLATE=C.UTF-8),
# grouped into the 3 categories below:
#  - general patterns (match in all directories)
#  - patterns to match files at the toplevel
#  - patterns to match files in subdirs

# general patterns
*.pyc
*.rpm

# toplevel (/...)
/Test*.html
/Test*.json
/Test*.log
/Test*.log.gz
/Test*.png
/*.whl
/bots
/cockpit-*.spec
/cockpit-*.tar.xz
/cockpit-navigator.spec
/deb-build/
/dist/
/metafile.json
/pkg/
/node_modules/
/runtime-npm-modules.txt
/tmp/
/tools/

# subdirs (/subdir/...)
/packaging/arch/PKGBUILD
/packaging/debian/changelog

# dpkg-buildpackage artifacts (debian/changelog + rules etc. stay tracked)
/debian/.debhelper/
/debian/cockpit-upside/
/debian/files
/debian/debhelper-build-stamp
/debian/*.substvars
/po/*.pot
/po/LINGUAS
/test/common/
/test/images/
/test/static-code
